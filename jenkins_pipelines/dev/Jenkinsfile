// Circle Guard — DEV Pipeline
// Stages: Checkout → Build → Unit Tests → Integration Tests → E2E Tests → Deploy → Smoke Tests
// Trigger: webhook on push to master

pipeline {

    agent any

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    environment {
        NS              = 'circle-guard-dev'
        COMPOSE_FILE    = 'docker-compose.test.yml'
        SERVICES        = 'auth identity promotion notification form gateway'
        IMAGE_PREFIX    = 'circle-guard'
        BUILD_TAG       = "${env.BUILD_NUMBER ?: 'local'}"
        KUBECONFIG      = credentials('kubeconfig-dev')        // Jenkins credential
        NOTIFY_EMAIL    = 'dev-team@circleguard.local'
    }

    stages {

        // ── 1. CHECKOUT ──────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    def commit = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    def author  = sh(script: 'git log -1 --format="%an"', returnStdout: true).trim()
                    def message = sh(script: 'git log -1 --format="%s"', returnStdout: true).trim()
                    echo "Commit : ${commit}"
                    echo "Author : ${author}"
                    echo "Message: ${message}"
                    currentBuild.description = "${commit} — ${message}"
                }
            }
        }

        // ── 2. BUILD IMAGES ───────────────────────────────────────────────────
        stage('Build Images') {
            steps {
                script {
                    def services = [
                        'auth'        : 'circleguard-auth-service',
                        'identity'    : 'circleguard-identity-service',
                        'promotion'   : 'circleguard-promotion-service',
                        'notification': 'circleguard-notification-service',
                        'form'        : 'circleguard-form-service',
                        'gateway'     : 'circleguard-gateway-service'
                    ]
                    def builds = [:]
                    services.each { short, dir ->
                        def s = short; def d = dir
                        builds["Build ${s}"] = {
                            sh """
                                docker build \
                                    -f services/${d}/Dockerfile \
                                    -t ${IMAGE_PREFIX}-${s}-service:latest \
                                    -t ${IMAGE_PREFIX}-${s}-service:${BUILD_TAG} \
                                    .
                            """
                        }
                    }
                    parallel builds
                }
            }
        }

        // ── 3. UNIT TESTS ─────────────────────────────────────────────────────
        stage('Unit Tests') {
            options {
                retry(2)
            }
            steps {
                sh './gradlew test --info --continue -x :tests:integration:test -x :tests:e2e:test'
            }
            post {
                always {
                    junit(
                        testResults: '**/build/test-results/test/*.xml',
                        allowEmptyResults: false
                    )
                }
                failure {
                    echo 'Unit tests failed — see JUnit report above'
                }
            }
        }

        // ── 4. INTEGRATION TESTS ──────────────────────────────────────────────
        stage('Integration Tests') {
            options {
                retry(2)
                timeout(time: 10, unit: 'MINUTES')
            }
            steps {
                sh 'mkdir -p logs'
                sh "docker-compose -f ${COMPOSE_FILE} up -d"
                sh '''
                    echo "Waiting 30s for healthchecks..."
                    sleep 30
                    docker-compose -f docker-compose.test.yml ps
                '''
                sh 'chmod +x tests/integration/run_integration_tests.sh'
                sh './tests/integration/run_integration_tests.sh'
            }
            post {
                always {
                    sh "docker-compose -f ${COMPOSE_FILE} down --remove-orphans || true"
                    junit(
                        testResults: 'tests/integration/build/test-results/**/*.xml',
                        allowEmptyResults: true
                    )
                }
                failure {
                    sh "docker-compose -f ${COMPOSE_FILE} logs > logs/integration-compose.log 2>&1 || true"
                    echo 'Integration tests failed — compose logs saved to logs/integration-compose.log'
                }
            }
        }

        // ── 5. E2E TESTS ──────────────────────────────────────────────────────
        stage('E2E Tests') {
            options {
                retry(2)
                timeout(time: 15, unit: 'MINUTES')
            }
            steps {
                sh 'chmod +x tests/e2e/run_e2e_tests.sh'
                sh './tests/e2e/run_e2e_tests.sh'
            }
            post {
                always {
                    junit(
                        testResults: 'tests/e2e/build/test-results/**/*.xml',
                        allowEmptyResults: true
                    )
                    publishHTML(target: [
                        allowMissing         : true,
                        alwaysLinkToLastBuild: true,
                        keepAll              : true,
                        reportDir            : 'tests/e2e/build/reports/tests/test',
                        reportFiles          : 'index.html',
                        reportName           : 'E2E Test Report'
                    ])
                }
                failure {
                    echo 'E2E tests failed — HTML report published above'
                }
            }
        }

        // ── 6. DEPLOY TO DEV K8S ──────────────────────────────────────────────
        stage('Deploy to Dev K8s') {
            options {
                timeout(time: 5, unit: 'MINUTES')
            }
            steps {
                script {
                    // Ensure namespace exists
                    sh """
                        kubectl get namespace ${NS} > /dev/null 2>&1 || \
                        kubectl create namespace ${NS}
                    """
                    // Apply manifests
                    sh "kubectl apply -k kubernetes_manifests/dev/"
                    // Wait for all deployments to roll out
                    def deployments = ['auth', 'identity', 'promotion', 'notification', 'form', 'gateway']
                    deployments.each { svc ->
                        sh """
                            kubectl rollout status deployment/${svc}-service \
                                -n ${NS} --timeout=120s
                        """
                    }
                    // Final check: all pods Running
                    sh """
                        kubectl wait pod \
                            --all -n ${NS} \
                            --for=condition=Ready \
                            --timeout=120s
                    """
                    sh "kubectl get pods -n ${NS}"
                }
            }
            post {
                failure {
                    sh "kubectl get events -n ${NS} --sort-by=.metadata.creationTimestamp > logs/k8s-events.log 2>&1 || true"
                    sh "kubectl describe pods -n ${NS} >> logs/k8s-events.log 2>&1 || true"
                    echo 'K8s deploy failed — events saved to logs/k8s-events.log (NOT rolling back — leaving for debug)'
                }
            }
        }

        // ── 7. SMOKE TESTS ────────────────────────────────────────────────────
        stage('Smoke Tests') {
            options {
                timeout(time: 3, unit: 'MINUTES')
            }
            steps {
                script {
                    // Resolve ClusterIP for each service (works when Jenkins agent is in-cluster)
                    // Falls back to port-forward when running outside the cluster
                    def endpoints = [
                        [name: 'auth',         svc: 'auth-service',         path: '/actuator/health'],
                        [name: 'identity',     svc: 'identity-service',     path: '/actuator/health'],
                        [name: 'promotion',    svc: 'promotion-service',    path: '/actuator/health'],
                        [name: 'notification', svc: 'notification-service', path: '/actuator/health'],
                        [name: 'form',         svc: 'form-service',         path: '/actuator/health'],
                        [name: 'gateway',      svc: 'gateway-service',      path: '/actuator/health'],
                    ]

                    def failures = []
                    endpoints.each { ep ->
                        def url = "http://${ep.svc}.${NS}.svc.cluster.local:8080${ep.path}"
                        def status = sh(
                            script: "curl -sf --max-time 10 -o /dev/null -w '%{http_code}' '${url}'",
                            returnStdout: true
                        ).trim()
                        if (status == '200') {
                            echo "[OK] ${ep.name} → HTTP ${status}"
                        } else {
                            echo "[FAIL] ${ep.name} → HTTP ${status}"
                            failures.add(ep.name)
                        }
                    }

                    if (failures) {
                        echo "Smoke failed for: ${failures.join(', ')} — rolling back"
                        failures.each { svc ->
                            sh "kubectl rollout undo deployment/${svc}-service -n ${NS} || true"
                        }
                        error("Smoke tests failed for: ${failures.join(', ')}")
                    } else {
                        echo 'All smoke tests passed!'
                    }
                }
            }
        }
    }

    // ── POST ──────────────────────────────────────────────────────────────────
    post {

        always {
            // Ensure compose is always stopped even on unexpected abort
            sh "docker-compose -f ${COMPOSE_FILE} down --remove-orphans 2>/dev/null || true"

            // Archive all logs and reports
            archiveArtifacts(
                artifacts: 'logs/**,**/build/reports/**',
                allowEmptyArchive: true,
                fingerprint: false
            )
        }

        failure {
            // Collect logs from every running container
            sh '''
                mkdir -p logs
                docker ps -q | xargs -I{} sh -c \
                    "docker inspect --format='{{.Name}}' {} | tr -d '/' | xargs -I NAME docker logs {} > logs/NAME.log 2>&1" \
                    || true
            '''
            emailext(
                to: "${NOTIFY_EMAIL}",
                subject: "FAILURE: Circle Guard DEV — Build #${BUILD_NUMBER}",
                body: """
                    Pipeline FAILED on stage: ${currentBuild.currentResult}
                    Branch  : ${env.BRANCH_NAME ?: 'master'}
                    Commit  : ${currentBuild.description ?: 'n/a'}
                    Duration: ${currentBuild.durationString}
                    Logs    : ${BUILD_URL}console
                """.stripIndent()
            )
        }

        success {
            emailext(
                to: "${NOTIFY_EMAIL}",
                subject: "SUCCESS: Circle Guard DEV — Build #${BUILD_NUMBER}",
                body: """
                    Pipeline PASSED — DEV environment updated.
                    Branch  : ${env.BRANCH_NAME ?: 'master'}
                    Commit  : ${currentBuild.description ?: 'n/a'}
                    Duration: ${currentBuild.durationString}
                    Report  : ${BUILD_URL}E2E_20Test_20Report/
                """.stripIndent()
            )
        }
    }
}
